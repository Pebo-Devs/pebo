<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pebo" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#120D0B</item>
        <item name="android:statusBarColor">#120D0B</item>
        <item name="android:navigationBarColor">#120D0B</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.Pebo.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#120D0B</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_pebo_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Pebo</item>
    </style>
</resources>
